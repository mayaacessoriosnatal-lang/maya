<script>
const CONFIG = {
  sheetId: '1VhIJVylpKAHnLfjBgopYRqd4nSM6d56d2xnlrwHgm4o',
  sheetName: 'Produtos',
};

const catLabel = c => ({'brinco':'Brincos','colar':'Colares','bolsa':'Bolsas','kit':'Kit & Combo','anel':'Aneis','pulseira':'Pulseiras'}[c?.toLowerCase()] || c || '&#8212;');
const fmt = v => isNaN(v) || v === '' ? '&#8212;' : 'R$ ' + Number(v).toFixed(2).replace('.',',');
const fmtPct = v => isNaN(v) ? '&#8212;' : Math.round(v) + '%';

function parseDate(str) {
  if (!str) return null;
  const s = String(str).trim();
  if (s.includes('/')) {
    const parts = s.split('/');
    if (parts.length === 3) {
      const [d, m, y] = parts;
      const date = new Date(`${y.trim()}-${m.trim().padStart(2,'0')}-${d.trim().padStart(2,'0')}`);
      return isNaN(date) ? null : date;
    }
  }
  const d = new Date(s);
  return isNaN(d) ? null : d;
}

function parseLine(line) {
  const result = [], re = /("([^"]*(?:""[^"]*)*)"|([^,]*))(,|$)/g;
  let m;
  while ((m = re.exec(line)) !== null) {
    result.push(m[2] !== undefined ? m[2].replace(/""/g,'"') : m[3]);
    if (m[4] === '') break;
  }
  return result;
}

function parseCSV(text) {
  const lines = text.trim().split('\n');
  const headers = parseLine(lines[0]).map(h => h.trim().toLowerCase()
    .replace('preco','preco').replace(/pre[cç]o/,'preco')
    .replace(/varia[cç][oõ]es/,'variacoes'));
  return lines.slice(1).map(line => {
    const vals = parseLine(line);
    const obj = {};
    headers.forEach((h,i) => obj[h] = (vals[i]||'').trim());
    if (obj['preco'] === undefined) obj.preco = obj['preço'] || '';
    if (obj['variacoes'] === undefined) obj.variacoes = obj['variações'] || '';
    const estoqueRaw = obj.estoque ?? obj['estoque'] ?? '';
    const estoqueParsed = parseInt(String(estoqueRaw).trim());
    obj.estoque = !isNaN(estoqueParsed) ? estoqueParsed : -1;
    return obj;
  }).filter(p => p.nome);
}

function calcMargem(preco, custo) {
  const p = parseFloat(preco), c = parseFloat(custo);
  if (!p || !c || isNaN(p) || isNaN(c)) return null;
  return ((p - c) / p) * 100;
}

function calcGiro(entrada, saida) {
  const d1 = parseDate(entrada), d2 = saida ? parseDate(saida) : new Date();
  if (!d1) return null;
  return Math.max(0, Math.floor((d2 - d1) / 86400000));
}

function isVendido(x) {
  const temDataVenda = x.data_venda && String(x.data_venda).trim() !== '';
  const temPedido = x.pedido && String(x.pedido).trim() !== '';
  return temDataVenda || temPedido || x.estoque === 0;
}

function isAtivo(x) {
  return !isVendido(x);
}

let chartVendasInstance = null;
let allProducts = [];
let periodoAtual = 7;

function setPeriodo(dias, btn) {
  periodoAtual = dias;
  document.querySelectorAll('.periodo-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  renderChartVendas(allProducts);
}

async function loadData() {
  document.getElementById('lastUpdate').textContent = 'Atualizando...';
  const url = `https://docs.google.com/spreadsheets/d/${CONFIG.sheetId}/gviz/tq?tqx=out:csv&sheet=${encodeURIComponent(CONFIG.sheetName)}`;
  try {
    const res = await fetch(url);
    if (!res.ok) throw new Error('Erro ao buscar planilha');
    allProducts = parseCSV(await res.text());
  } catch(e) {
    document.getElementById('tabelaProdutos').innerHTML = `<tr><td colspan="12"><div class="state-msg"><p>Erro: ${e.message}</p></div></td></tr>`;
    document.getElementById('lastUpdate').textContent = 'Erro';
    return;
  }
  renderKPIs(allProducts);
  renderFinanceiro(allProducts);
  renderChartVendas(allProducts);
  renderAlertas(allProducts);
  renderInsights(allProducts);
  renderCampeoes(allProducts);
  renderLucroCat(allProducts);
  renderTabela(allProducts);
  document.getElementById('lastUpdate').textContent = 'Atualizado as ' + new Date().toLocaleTimeString('pt-BR',{hour:'2-digit',minute:'2-digit'});
}

function calcTicketPorPedido(vendidos) {
  // agrupa por numero de pedido se existir, senão usa ticket por peça
  const comPedido = vendidos.filter(x => x.pedido && x.pedido.trim());
  if (!comPedido.length) return null;
  const pedidos = {};
  comPedido.forEach(x => {
    const id = x.pedido.trim();
    if (!pedidos[id]) pedidos[id] = 0;
    pedidos[id] += parseFloat(x.preco) || 0;
  });
  const valores = Object.values(pedidos);
  return valores.length ? valores.reduce((s,v) => s+v, 0) / valores.length : null;
}

function calcTotalPedidos(vendidos) {
  const comPedido = vendidos.filter(x => x.pedido && x.pedido.trim());
  if (!comPedido.length) return vendidos.length;
  return new Set(comPedido.map(x => x.pedido.trim())).size;
}

function renderKPIs(p) {
  const vendidos = p.filter(isVendido);
  const receita = vendidos.reduce((s,x) => s + (parseFloat(x.preco)||0), 0);
  const custo = vendidos.reduce((s,x) => s + (parseFloat(x.custo)||0), 0);
  const lucro = receita - custo;
  const comMargem = p.filter(x => calcMargem(x.preco,x.custo) !== null);
  const margemMedia = comMargem.length ? comMargem.reduce((s,x) => s + calcMargem(x.preco,x.custo), 0) / comMargem.length : null;
  const ticket = calcTicketPorPedido(vendidos) || (vendidos.length ? receita / vendidos.length : null);
  const comGiro = vendidos.filter(x => calcGiro(x.data_entrada, x.data_venda) !== null);
  const giroMedio = comGiro.length ? Math.round(comGiro.reduce((s,x) => s + calcGiro(x.data_entrada, x.data_venda), 0) / comGiro.length) : null;
  const totalPedidos = calcTotalPedidos(vendidos);

  // Pecas disponiveis e vendidas
  const pecasDisponiveis = p.filter(x => {
    const e = x.estoque;
    return !isNaN(e) && e !== 0 && e !== -1;
  }).length;
  const pecasVendidas = vendidos.length;

  // Vendidas por categoria
  const catVendidas = {};
  vendidos.forEach(x => {
    const c = catLabel(x.categoria);
    catVendidas[c] = (catVendidas[c] || 0) + 1;
  });
  const catVendidasStr = Object.entries(catVendidas)
    .sort((a,b) => b[1]-a[1])
    .map(([c,n]) => `${c}: ${n}`)
    .join(' · ') || '&#8212;';

  document.getElementById('kpiReceita').textContent = receita > 0 ? fmt(receita) : '&#8212;';
  document.getElementById('kpiLucro').textContent = lucro > 0 ? fmt(lucro) : '&#8212;';
  document.getElementById('kpiMargem').textContent = margemMedia !== null ? fmtPct(margemMedia) : '&#8212;';
  document.getElementById('kpiTicket').textContent = ticket ? fmt(ticket) : '&#8212;';
  document.getElementById('kpiGiro').textContent = giroMedio !== null ? giroMedio + 'd' : '&#8212;';
  document.getElementById('kpiPecasDisponiveis').textContent = pecasDisponiveis;
  document.getElementById('kpiPecasVendidas').textContent = pecasVendidas;
  document.getElementById('kpiVendidasCat').innerHTML = catVendidasStr;
}

function renderFinanceiro(p) {
  const vendidos = p.filter(isVendido);
  const ativos = p.filter(isAtivo);
  const receita = vendidos.reduce((s,x) => s + (parseFloat(x.preco)||0), 0);
  const custoVendidos = vendidos.reduce((s,x) => s + (parseFloat(x.custo)||0), 0);
  const custoEstoque = ativos.reduce((s,x) => s + (parseFloat(x.custo)||0) * Math.max(1, x.estoque === -1 ? 1 : x.estoque), 0);
  const lucro = receita - custoVendidos;
  const potencial = ativos.reduce((s,x) => s + (parseFloat(x.preco)||0) * Math.max(1, x.estoque === -1 ? 1 : x.estoque), 0);

  document.getElementById('finReceita').textContent = fmt(receita);
  document.getElementById('finCusto').textContent = fmt(custoVendidos);
  document.getElementById('finEstoqueCusto').textContent = fmt(custoEstoque);
  document.getElementById('finLucro').textContent = fmt(lucro);
  document.getElementById('finPotencial').textContent = fmt(potencial);

  // Margem por categoria
  const cats = {};
  p.forEach(x => {
    const c = catLabel(x.categoria);
    const m = calcMargem(x.preco, x.custo);
    if (m !== null) { if (!cats[c]) cats[c] = []; cats[c].push(m); }
  });
  const catMedias = Object.entries(cats).map(([c,ms]) => [c, ms.reduce((s,v)=>s+v,0)/ms.length]).sort((a,b)=>b[1]-a[1]);
  const maxM = catMedias.length ? catMedias[0][1] : 100;
  document.getElementById('chartCategoriaMargem').innerHTML = catMedias.length
    ? catMedias.map(([c,m]) => `<div class="bar-row"><div class="bar-label">${c}</div><div class="bar-bg"><div class="bar-fill verde" style="width:${Math.round((m/maxM)*100)}%"></div></div><div class="bar-num">${fmtPct(m)}</div></div>`).join('')
    : '<div class="alerta-vazio">Adicione coluna custo na planilha</div>';
}

function renderChartVendas(p) {
  const vendidos = p.filter(x => isVendido(x) && x.data_venda);
  if (!vendidos.length) {
    if (chartVendasInstance) { chartVendasInstance.destroy(); chartVendasInstance = null; }
    const ctx = document.getElementById('chartVendas').getContext('2d');
    ctx.clearRect(0,0,ctx.canvas.width,ctx.canvas.height);
    return;
  }

  const hoje = new Date();
  const dias = periodoAtual === 0 ? 365 : periodoAtual;
  const inicio = new Date(hoje); inicio.setDate(inicio.getDate() - dias);

  // Montar labels de datas
  const labels = [];
  const dataMap = {};
  for (let i = dias; i >= 0; i--) {
    const d = new Date(hoje); d.setDate(d.getDate() - i);
    const key = d.toISOString().split('T')[0];
    labels.push(key);
    dataMap[key] = 0;
  }

  vendidos.forEach(x => {
    const dateStr = x.data_venda;
    const d = parseDate(dateStr);
    if (!d || d < inicio) return;
    const key = d.toISOString().split('T')[0];
    if (dataMap[key] !== undefined) dataMap[key] += parseFloat(x.preco) || 0;
  });

  const valores = labels.map(l => dataMap[l]);
  // acumulado
  const acumulado = [];
  let soma = 0;
  valores.forEach(v => { soma += v; acumulado.push(soma); });

  if (chartVendasInstance) chartVendasInstance.destroy();
  const ctx = document.getElementById('chartVendas').getContext('2d');
  chartVendasInstance = new Chart(ctx, {
    type: 'line',
    data: {
      labels: labels.map(l => { const d = new Date(l); return d.toLocaleDateString('pt-BR',{day:'2-digit',month:'2-digit'}); }),
      datasets: [
        {
          label: 'Receita diaria (R$)',
          data: valores,
          borderColor: '#E8856A',
          backgroundColor: 'rgba(232,133,106,0.08)',
          borderWidth: 2,
          pointRadius: 3,
          fill: true,
          tension: 0.4,
          yAxisID: 'y',
        },
        {
          label: 'Receita acumulada (R$)',
          data: acumulado,
          borderColor: '#C45E42',
          backgroundColor: 'transparent',
          borderWidth: 1.5,
          borderDash: [4,4],
          pointRadius: 0,
          fill: false,
          tension: 0.4,
          yAxisID: 'y1',
        }
      ]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      interaction: { mode: 'index', intersect: false },
      plugins: { legend: { labels: { font: { family: 'Jost', size: 10 }, color: '#7A5A4E' } } },
      scales: {
        x: { grid: { color: 'rgba(196,160,144,0.15)' }, ticks: { font: { family: 'Jost', size: 9 }, color: '#C4A090', maxTicksLimit: 10 } },
        y: { position: 'left', grid: { color: 'rgba(196,160,144,0.15)' }, ticks: { font: { family: 'Jost', size: 9 }, color: '#7A5A4E', callback: v => 'R$' + v.toFixed(0) } },
        y1: { position: 'right', grid: { drawOnChartArea: false }, ticks: { font: { family: 'Jost', size: 9 }, color: '#C45E42', callback: v => 'R$' + v.toFixed(0) } },
      }
    }
  });
}

function renderAlertas(p) {
  const ultimas = p.filter(x => isAtivo(x) && x.estoque === 1);
  const elEst = document.getElementById('alertaEstoque');
  elEst.innerHTML = ultimas.length
    ? ultimas.map(x => `<div class="alerta-item"><span>${x.nome}</span><span>${catLabel(x.categoria)}</span></div>`).join('')
    : '<div class="alerta-vazio">Nenhum produto em alerta &#10003;</div>';

  const lentos = p.filter(x => { if (!isAtivo(x)) return false; const d = calcGiro(x.data_entrada, null); return d !== null && d > 20; });
  const elGiro = document.getElementById('alertaGiro');
  elGiro.innerHTML = lentos.length
    ? lentos.map(x => `<div class="alerta-item"><span>${x.nome}</span><span>${calcGiro(x.data_entrada,null)}d</span></div>`).join('')
    : '<div class="alerta-vazio">Nenhum produto em alerta &#10003;</div>';
}

function renderInsights(p) {
  const vendidos = p.filter(isVendido);
  const ativos = p.filter(isAtivo);

  // Mais rentavel
  const rentavel = p.filter(x => calcMargem(x.preco,x.custo) !== null).sort((a,b) => calcMargem(b.preco,b.custo) - calcMargem(a.preco,a.custo))[0];
  document.getElementById('insProdRentavel').textContent = rentavel ? rentavel.nome : '&#8212;';
  document.getElementById('insProdRentavelDesc').textContent = rentavel ? `Margem de ${fmtPct(calcMargem(rentavel.preco,rentavel.custo))} sobre o preco de venda` : 'Adicione custo na planilha';

  // Mais rapido
  const comGiro = vendidos.filter(x => calcGiro(x.data_entrada,x.data_venda) !== null).sort((a,b) => calcGiro(a.data_entrada,a.data_venda) - calcGiro(b.data_entrada,b.data_venda));
  const rapido = comGiro[0];
  document.getElementById('insProdRapido').textContent = rapido ? rapido.nome : '&#8212;';
  document.getElementById('insProdRapidoDesc').textContent = rapido ? `Vendido em ${calcGiro(rapido.data_entrada,rapido.data_venda)} dias` : 'Sem vendas registradas ainda';

  // Categoria mais vendida
  const catCount = {};
  vendidos.forEach(x => { const c = catLabel(x.categoria); catCount[c] = (catCount[c]||0)+1; });
  const topCat = Object.entries(catCount).sort((a,b)=>b[1]-a[1])[0];
  document.getElementById('insCategoria').textContent = topCat ? topCat[0] : '&#8212;';
  document.getElementById('insCategoriaDesc').textContent = topCat ? `${topCat[1]} pecas vendidas nesta categoria` : 'Sem vendas registradas ainda';

  // Ticket medio
  const receita = vendidos.reduce((s,x)=>s+(parseFloat(x.preco)||0),0);
  const ticketPedido = calcTicketPorPedido(vendidos);
  const totalPedidos = calcTotalPedidos(vendidos);
  const ticket = ticketPedido || (vendidos.length ? receita / vendidos.length : null);
  const descTicket = ticketPedido
    ? `Media por pedido (${totalPedidos} pedido${totalPedidos>1?'s':''})`
    : `Media por peca (${vendidos.length} vendidas)`;
  document.getElementById('insTicket').textContent = ticket ? fmt(ticket) : '&#8212;';
  document.getElementById('insTicketDesc').textContent = ticket ? descTicket : 'Sem vendas registradas';

  // Estoque em risco (giro lento > 20d)
  const risco = ativos.filter(x => { const d = calcGiro(x.data_entrada,null); return d !== null && d > 20; });
  document.getElementById('insRisco').textContent = risco.length > 0 ? risco.length + ' produto' + (risco.length>1?'s':'') : 'Nenhum';
  document.getElementById('insRiscoDesc').textContent = risco.length > 0 ? `Em estoque ha mais de 20 dias sem vender` : 'Todos os produtos estao girando bem';

  // Receita potencial
  const potencial = ativos.reduce((s,x)=>s+(parseFloat(x.preco)||0)*Math.max(1,x.estoque===-1?1:x.estoque),0);
  document.getElementById('insPotencial').textContent = fmt(potencial);
  document.getElementById('insPotencialDesc').textContent = `Se vender todo o estoque atual`;
}

function recompraBadge(dias, margem, vendido) {
  if (!vendido) return '<span class="recompra-nd">em estoque</span>';
  if (dias === null && margem === null) return '<span class="recompra-nd">sem dados</span>';
  // Margem baixa tem prioridade
  if (margem !== null && margem < 45) return '<span class="recompra-margem">So se vender muito</span>';
  // Regras por giro
  if (dias !== null) {
    if (dias <= 7 && margem !== null && margem >= 60) return '<span class="recompra-sim">&#10003; Recomprar</span>';
    if (dias <= 7) return '<span class="recompra-testar">Testar similar</span>';
    if (dias <= 20) return '<span class="recompra-testar">Testar similar</span>';
    if (dias > 20) return '<span class="recompra-nao">&#215; Nao recomprar</span>';
  }
  return '<span class="recompra-nd">sem dados</span>';
}

function renderCampeoes(p) {
  const vendidos = p.filter(isVendido);
  const campeoes = vendidos
    .filter(x => calcGiro(x.data_entrada, x.data_venda) !== null && calcGiro(x.data_entrada, x.data_venda) <= 4)
    .sort((a,b) => calcGiro(a.data_entrada, a.data_venda) - calcGiro(b.data_entrada, b.data_venda))
    .slice(0, 9);

  const grid = document.getElementById('campeoesGrid');
  if (!campeoes.length) {
    grid.innerHTML = '<div style="color:var(--light);font-size:11px;letter-spacing:2px;">Nenhum produto vendido em ate 4 dias ainda.</div>';
    return;
  }
  grid.innerHTML = campeoes.map((x, i) => {
    const dias = calcGiro(x.data_entrada, x.data_venda);
    const margem = calcMargem(x.preco, x.custo);
    return `<div class="campeao-card">
      <div class="campeao-rank">${String(i+1).padStart(2,'0')}</div>
      <div class="campeao-nome">${x.nome}</div>
      <div class="campeao-info">${dias}d de giro &middot; ${catLabel(x.categoria)}${margem !== null ? ' &middot; ' + fmtPct(margem) + ' margem' : ''}</div>
    </div>`;
  }).join('');
}

function renderLucroCat(p) {
  const vendidos = p.filter(isVendido);

  // Lucro por categoria
  const cats = {};
  vendidos.forEach(x => {
    const c = catLabel(x.categoria);
    if (!cats[c]) cats[c] = { receita: 0, custo: 0, qtd: 0 };
    cats[c].receita += parseFloat(x.preco) || 0;
    cats[c].custo += parseFloat(x.custo) || 0;
    cats[c].qtd += 1;
  });

  const catList = Object.entries(cats)
    .map(([c, d]) => ({ cat: c, lucro: d.receita - d.custo, margem: d.receita > 0 ? ((d.receita - d.custo) / d.receita) * 100 : 0, qtd: d.qtd, receita: d.receita }))
    .sort((a,b) => b.lucro - a.lucro);

  const el = document.getElementById('lucroCatTabela');
  if (!catList.length) { el.innerHTML = '<div class="alerta-vazio">Sem vendas ainda</div>'; }
  else {
    el.innerHTML = `<table style="width:100%;border-collapse:collapse;">
      <thead><tr>
        <th style="font-size:8px;letter-spacing:3px;text-transform:uppercase;color:var(--light);padding:8px 0;text-align:left;border-bottom:1px solid var(--peach-pale);">Categoria</th>
        <th style="font-size:8px;letter-spacing:3px;text-transform:uppercase;color:var(--light);padding:8px 0;text-align:right;border-bottom:1px solid var(--peach-pale);">Lucro</th>
        <th style="font-size:8px;letter-spacing:3px;text-transform:uppercase;color:var(--light);padding:8px 0;text-align:right;border-bottom:1px solid var(--peach-pale);">Margem</th>
        <th style="font-size:8px;letter-spacing:3px;text-transform:uppercase;color:var(--light);padding:8px 0;text-align:right;border-bottom:1px solid var(--peach-pale);">Pecas</th>
        <th style="font-size:8px;letter-spacing:3px;text-transform:uppercase;color:var(--light);padding:8px 0;text-align:center;border-bottom:1px solid var(--peach-pale);">Prioridade</th>
      </tr></thead>
      <tbody>${catList.map(d => {
        const prioridade = d.margem >= 60 && d.qtd >= 3 ? '<span class="recompra-sim">&#11088; Alta</span>'
          : d.margem >= 60 || d.qtd >= 3 ? '<span class="recompra-testar">Media</span>'
          : '<span class="recompra-nao">Baixa</span>';
        return `<tr>
          <td style="padding:10px 0;font-size:12px;border-bottom:1px solid var(--peach-pale);">${d.cat}</td>
          <td style="padding:10px 0;font-size:12px;text-align:right;color:var(--green);border-bottom:1px solid var(--peach-pale);">${fmt(d.lucro)}</td>
          <td style="padding:10px 0;font-size:12px;text-align:right;border-bottom:1px solid var(--peach-pale);">${fmtPct(d.margem)}</td>
          <td style="padding:10px 0;font-size:12px;text-align:right;border-bottom:1px solid var(--peach-pale);">${d.qtd}</td>
          <td style="padding:10px 0;text-align:center;border-bottom:1px solid var(--peach-pale);">${prioridade}</td>
        </tr>`;
      }).join('')}</tbody>
    </table>`;
  }

  // Pecas por pedido
  const comPedido = vendidos.filter(x => x.pedido && x.pedido.trim());
  const pedidos = {};
  comPedido.forEach(x => {
    const id = x.pedido.trim();
    pedidos[id] = (pedidos[id] || 0) + 1;
  });
  const vals = Object.values(pedidos);
  const media = vals.length ? vals.reduce((s,v)=>s+v,0) / vals.length : null;
  const max = vals.length ? Math.max(...vals) : null;
  const total = vals.length;

  const elInfo = document.getElementById('pecasPorPedidoInfo');
  elInfo.innerHTML = media ? `<p style="font-size:11px;color:var(--mid);margin-bottom:16px;line-height:1.8;">Baseado em <strong>${total} pedido${total>1?'s':''}</strong> com numero registrado.</p>` : '<p style="font-size:11px;color:var(--light);margin-bottom:16px;">Adicione a coluna "pedido" na planilha para ver.</p>';

  const elGrid = document.getElementById('pecasPedidoGrid');
  elGrid.innerHTML = `
    <div class="pp-item">
      <div class="pp-label">Media</div>
      <div class="pp-val">${media ? media.toFixed(1) : '&#8212;'}</div>
      <div class="pp-meta">Meta: 3+</div>
    </div>
    <div class="pp-item">
      <div class="pp-label">Maior pedido</div>
      <div class="pp-val">${max || '&#8212;'}</div>
      <div class="pp-meta">pecas</div>
    </div>
    <div class="pp-item">
      <div class="pp-label">Pedidos registrados</div>
      <div class="pp-val">${total || '&#8212;'}</div>
      <div class="pp-meta">com numero</div>
    </div>`;
}

function gerarSKU(p) {
  if (p.sku && p.sku.trim()) return p.sku.trim().toUpperCase();
  const tipoMap = {'brinco':'BRI','colar':'COL','anel':'ANL','pulseira':'PUL','bolsa':'BOL','kit':'KIT'};
  const tipo = tipoMap[p.categoria?.toLowerCase()] || 'GER';
  const vars = p.variacoes ? p.variacoes.split(',').map(v=>v.trim()) : [];
  const matMap = {'ouro':'OUR','prata':'PRT','dourado':'OUR','prateado':'PRT','rose':'ROS'};
  const mat = vars.length ? (matMap[vars[0].toLowerCase()] || vars[0].substring(0,3).toUpperCase()) : 'UNI';
  const tam = vars[1] ? vars[1].substring(0,3).toUpperCase() : 'UN';
  return `${tipo}-${mat}-${tam}`;
}

function statusBadge(estoque) {
  if (estoque === 0) return '<span class="badge badge-esgotado">Esgotado</span>';
  if (estoque === 1) return '<span class="badge badge-ultimas">Ultima un.</span>';
  if (estoque === -1) return '<span class="badge badge-ativo">Sem controle</span>';
  return '<span class="badge badge-ativo">Ativo</span>';
}

function statusBadgeProduto(x) {
  if (isVendido(x)) return '<span class="badge badge-esgotado">Vendido</span>';
  return statusBadge(x.estoque);
}

function giroBadge(dias, vendido) {
  if (dias === null) return '<span class="giro-aberto">sem data</span>';
  if (vendido) {
    if (dias <= 7) return `<span class="giro-badge giro-rapido">${dias}d rapido</span>`;
    if (dias <= 20) return `<span class="giro-badge giro-medio">${dias}d medio</span>`;
    return `<span class="giro-badge giro-lento">${dias}d lento</span>`;
  }
  return `<span class="giro-aberto">${dias}d em estoque</span>`;
}

function renderTabela(p) {
  if (!p.length) {
    document.getElementById('tabelaProdutos').innerHTML = '<tr><td colspan="12"><div class="state-msg"><p>Nenhum produto</p></div></td></tr>';
    return;
  }
  document.getElementById('tabelaProdutos').innerHTML = p.map(x => {
    const vendido = isVendido(x);
    const margem = calcMargem(x.preco, x.custo);
    const dias = calcGiro(x.data_entrada, vendido ? x.data_venda : null);
    return `<tr>
      <td><div class="td-nome">${x.nome}</div></td>
      <td><span style="font-size:9px;letter-spacing:2px;color:var(--mid)">${gerarSKU(x)}</span></td>
      <td><div class="td-cat">${catLabel(x.categoria)}</div></td>
      <td>${fmt(x.preco)}</td>
      <td>${x.custo ? fmt(x.custo) : '<span style="color:var(--light);font-size:10px">&#8212;</span>'}</td>
      <td>${margem !== null ? `<div class="margem-wrap"><div class="margem-bar-bg"><div class="margem-bar-fill" style="width:${Math.min(100,Math.round(margem))}%"></div></div><div class="margem-val">${fmtPct(margem)}</div></div>` : '<span style="color:var(--light);font-size:10px">sem custo</span>'}</td>
      <td>${x.estoque === -1 ? '<span style="color:var(--light)">&#8212;</span>' : x.estoque}</td>
      <td>${statusBadgeProduto(x)}</td>
      <td style="font-size:10px;color:var(--mid)">${x.data_entrada||'&#8212;'}</td>
      <td style="font-size:10px;color:var(--mid)">${x.data_venda||'&#8212;'}</td>
      <td>${giroBadge(dias, vendido)}</td>
      <td>${recompraBadge(dias, margem, vendido)}</td>
    </tr>`;
  }).join('');
}

loadData();
</script>
</body>
</html>
