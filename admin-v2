<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>MAYA &#8212; Gestao</title>
<link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>&#10022;</text></svg>">
<link href="https://fonts.googleapis.com/css2?family=Jost:wght@100;200;300;400;500&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<style>
@font-face { font-family:'Melora'; src:url('data:font/otf;base64,') format('opentype'); }
:root {
  --peach:#E8856A; --peach-light:#F2A98E; --peach-pale:#F9DDD4;
  --peach-deep:#C45E42; --white:#FEFAF8; --off:#F5EDE8;
  --dark:#2A1F1A; --mid:#7A5A4E; --light:#C4A090;
  --green:#5A8A6A; --green-pale:#D4EAD8;
  --red:#A04040; --red-pale:#EAD4D4;
  --yellow:#A08040; --yellow-pale:#EAE0D4;
}
*{margin:0;padding:0;box-sizing:border-box;}
body{background:var(--off);color:var(--dark);font-family:'Jost',sans-serif;font-weight:300;min-height:100vh;}

/* TOP BAR */
.topbar{background:var(--dark);padding:18px 48px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:100;}
.topbar-logo{font-family:'Melora',serif;font-size:22px;color:var(--white);letter-spacing:2px;}
.topbar-sub{font-size:9px;letter-spacing:5px;text-transform:uppercase;color:var(--peach);margin-top:2px;}
.topbar-right{display:flex;align-items:center;gap:20px;}
.btn-refresh{font-size:9px;letter-spacing:3px;text-transform:uppercase;background:none;border:1px solid rgba(232,133,106,.4);color:var(--peach-light);padding:10px 20px;cursor:pointer;font-family:'Jost',sans-serif;transition:all .2s;}
.btn-refresh:hover{background:var(--peach);border-color:var(--peach);color:var(--white);}
.last-update{font-size:9px;letter-spacing:2px;color:var(--mid);text-transform:uppercase;}

/* LAYOUT */
.container{padding:40px 48px;max-width:1400px;margin:0 auto;}

/* KPI CARDS */
.kpi-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:16px;margin-bottom:40px;}
.kpi{background:var(--white);padding:24px 28px;border-left:3px solid var(--peach-pale);}
.kpi.destaque{border-left-color:var(--peach);}
.kpi.verde{border-left-color:var(--green);}
.kpi-label{font-size:8px;letter-spacing:4px;text-transform:uppercase;color:var(--light);margin-bottom:10px;}
.kpi-value{font-family:'Georgia',serif;font-size:32px;color:var(--dark);line-height:1;}
.kpi-sub{font-size:10px;color:var(--mid);margin-top:6px;}

/* FINANCEIRO */
.fin-grid{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:40px;}
.fin-card{background:var(--white);padding:28px 32px;}
.fin-title{font-size:8px;letter-spacing:4px;text-transform:uppercase;color:var(--mid);margin-bottom:20px;}
.fin-row{display:flex;justify-content:space-between;align-items:center;padding:10px 0;border-bottom:1px solid var(--peach-pale);}
.fin-row:last-child{border-bottom:none;}
.fin-row-label{font-size:12px;color:var(--mid);}
.fin-row-value{font-size:14px;color:var(--dark);}
.fin-row-value.destaque{color:var(--peach-deep);font-family:'Georgia',serif;font-size:18px;}
.fin-row-value.verde{color:var(--green);}
.fin-row-value.vermelho{color:var(--red);}

/* GRAFICO */
.chart-section{margin-bottom:40px;}
.chart-card{background:var(--white);padding:28px 32px;}
.chart-title{font-size:8px;letter-spacing:4px;text-transform:uppercase;color:var(--mid);margin-bottom:24px;display:flex;justify-content:space-between;align-items:center;}
.chart-wrap{position:relative;height:240px;}
.periodo-btns{display:flex;gap:4px;}
.periodo-btn{font-size:8px;letter-spacing:2px;text-transform:uppercase;padding:5px 12px;border:1px solid var(--peach-pale);background:none;color:var(--mid);cursor:pointer;font-family:'Jost',sans-serif;transition:all .2s;}
.periodo-btn.active,.periodo-btn:hover{background:var(--peach);border-color:var(--peach);color:var(--white);}

/* ALERTAS */
.alertas{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:40px;}
.alerta{background:var(--white);padding:24px 28px;border-left:3px solid;}
.alerta.tipo-estoque{border-left-color:var(--peach-deep);}
.alerta.tipo-giro{border-left-color:var(--yellow);}
.alerta-titulo{font-size:8px;letter-spacing:4px;text-transform:uppercase;margin-bottom:12px;}
.alerta.tipo-estoque .alerta-titulo{color:var(--peach-deep);}
.alerta.tipo-giro .alerta-titulo{color:var(--yellow);}
.alerta-item{font-size:12px;color:var(--dark);padding:6px 0;border-bottom:1px solid var(--peach-pale);display:flex;justify-content:space-between;}
.alerta-item:last-child{border-bottom:none;}
.alerta-vazio{font-size:11px;color:var(--light);}

/* INSIGHTS */
.insights-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-bottom:40px;}
.insight{background:var(--white);padding:24px 28px;border-top:3px solid var(--peach-pale);}
.insight.destaque{border-top-color:var(--peach);}
.insight-icon{font-size:20px;margin-bottom:12px;}
.insight-titulo{font-size:8px;letter-spacing:3px;text-transform:uppercase;color:var(--light);margin-bottom:8px;}
.insight-valor{font-family:'Georgia',serif;font-size:24px;color:var(--dark);margin-bottom:6px;}
.insight-desc{font-size:11px;color:var(--mid);line-height:1.6;}

/* BAR CHART */
.bar-chart{display:flex;flex-direction:column;gap:10px;}
.bar-row{display:flex;align-items:center;gap:12px;}
.bar-label{font-size:10px;color:var(--mid);width:90px;text-align:right;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.bar-bg{flex:1;height:20px;background:var(--off);}
.bar-fill{height:100%;background:var(--peach);transition:width .8s ease;}
.bar-fill.verde{background:var(--green);}
.bar-num{font-size:10px;color:var(--dark);min-width:48px;}

/* BADGES */
.badge{display:inline-block;font-size:8px;letter-spacing:2px;text-transform:uppercase;padding:4px 10px;}
.badge-ativo{background:var(--green-pale);color:var(--green);}
.badge-ultimas{background:var(--yellow-pale);color:var(--yellow);}
.badge-esgotado{background:var(--red-pale);color:var(--red);}
.recompra-sim{background:#D4EAD8;color:#2A6A3A;font-size:8px;letter-spacing:2px;text-transform:uppercase;padding:4px 10px;display:inline-block;font-weight:500;}
.recompra-testar{background:#FFF3D4;color:#8A6A00;font-size:8px;letter-spacing:2px;text-transform:uppercase;padding:4px 10px;display:inline-block;}
.recompra-nao{background:#EAD4D4;color:#8A2A2A;font-size:8px;letter-spacing:2px;text-transform:uppercase;padding:4px 10px;display:inline-block;}
.recompra-margem{background:#F0E8E4;color:#7A5A4E;font-size:8px;letter-spacing:2px;text-transform:uppercase;padding:4px 10px;display:inline-block;}
.recompra-nd{color:var(--light);font-size:10px;}
.campeoes-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-bottom:40px;}
.campeao-card{background:var(--white);padding:20px 24px;border-left:3px solid var(--peach);}
.campeao-rank{font-family:'Georgia',serif;font-size:32px;color:var(--peach-pale);line-height:1;margin-bottom:8px;}
.campeao-nome{font-size:13px;color:var(--dark);margin-bottom:4px;}
.campeao-info{font-size:10px;color:var(--mid);}
.pecas-pedido-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-top:16px;}
.pp-item{background:var(--off);padding:12px 16px;text-align:center;}
.pp-label{font-size:8px;letter-spacing:3px;text-transform:uppercase;color:var(--light);margin-bottom:6px;}
.pp-val{font-family:'Georgia',serif;font-size:20px;color:var(--dark);}
.pp-meta{font-size:9px;color:var(--mid);margin-top:4px;}

/* MARGEM BAR */
.margem-wrap{display:flex;align-items:center;gap:10px;}
.margem-bar-bg{flex:1;height:4px;background:var(--peach-pale);min-width:60px;}
.margem-bar-fill{height:100%;background:var(--peach);}
.margem-val{font-size:11px;color:var(--dark);min-width:40px;}

/* GIRO */
.giro-badge{font-size:10px;padding:3px 10px;display:inline-block;}
.giro-rapido{background:var(--green-pale);color:var(--green);}
.giro-medio{background:var(--yellow-pale);color:var(--yellow);}
.giro-lento{background:var(--red-pale);color:var(--red);}
.giro-aberto{color:var(--light);font-size:10px;}

/* TABLE */
.section{margin-bottom:40px;}
.section-title{font-size:9px;letter-spacing:5px;text-transform:uppercase;color:var(--mid);margin-bottom:20px;padding-bottom:12px;border-bottom:1px solid var(--peach-pale);}
.table-wrap{background:var(--white);overflow-x:auto;}
table{width:100%;border-collapse:collapse;}
thead tr{background:var(--dark);}
thead th{font-size:8px;letter-spacing:3px;text-transform:uppercase;color:var(--peach-light);padding:14px 20px;text-align:left;font-weight:300;white-space:nowrap;}
tbody tr{border-bottom:1px solid var(--peach-pale);transition:background .15s;}
tbody tr:hover{background:var(--off);}
tbody td{font-size:12px;color:var(--dark);padding:16px 20px;vertical-align:middle;}
.td-nome{font-family:'Georgia',serif;font-size:14px;}
.td-cat{font-size:8px;letter-spacing:3px;text-transform:uppercase;color:var(--light);}

/* EMPTY */
.state-msg{text-align:center;padding:60px;color:var(--light);}
.state-msg .icon{font-family:'Georgia',serif;font-size:48px;margin-bottom:16px;opacity:.3;}
.state-msg p{font-size:11px;letter-spacing:2px;text-transform:uppercase;}
.admin-note{font-size:10px;color:var(--light);text-align:center;padding:32px;border-top:1px solid var(--peach-pale);margin-top:40px;line-height:2;}
</style>
</head>
<body>

